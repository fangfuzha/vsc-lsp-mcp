{
  "name": "lsp-mcp",
  "displayName": "LSP MCP",
  "version": "0.2.1",
  "description": "LSP MCP Server for VS Code",
  "publisher": "CJL",
  "author": "CJL <2662442385@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/beixiyo/vsc-lsp-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/beixiyo/vsc-lsp-mcp"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "res/icon.webp",
  "l10n": "./l10n",
  "files": [
    "LICENSE.md",
    "package.nls.json",
    "package.nls.*.json",
    "dist/*",
    "l10n/*",
    "res/*",
    "CHANGELOG.md"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [],
    "mcpServerDefinitionProviders": [
      {
        "id": "lsp-mcp.localServer",
        "label": "%lsp-mcp.mcpServerDefinitionProvider.localServer.label%"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%lsp-mcp.configuration.title%",
      "properties": {
        "lsp-mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%lsp-mcp.configuration.enabled.description%"
        },
        "lsp-mcp.port": {
          "type": "number",
          "default": 9527,
          "description": "%lsp-mcp.configuration.port.description%"
        },
        "lsp-mcp.maxRetries": {
          "type": "number",
          "default": 10,
          "description": "%lsp-mcp.configuration.maxRetries.description%"
        },
        "lsp-mcp.cors.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%lsp-mcp.configuration.cors.enabled.description%"
        },
        "lsp-mcp.cors.allowOrigins": {
          "type": "string",
          "default": "*",
          "description": "%lsp-mcp.configuration.cors.allowOrigins.description%"
        },
        "lsp-mcp.cors.withCredentials": {
          "type": "boolean",
          "default": false,
          "description": "%lsp-mcp.configuration.cors.withCredentials.description%"
        },
        "lsp-mcp.cors.exposeHeaders": {
          "type": "string",
          "default": "Mcp-Session-Id",
          "description": "%lsp-mcp.configuration.cors.exposeHeaders.description%"
        },
        "lsp-mcp.maxResults": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "%lsp-mcp.configuration.maxResults.description%"
        },
        "lsp-mcp.outputFormat": {
          "type": "string",
          "default": "json",
          "enum": [
            "json",
            "markdown"
          ],
          "description": "%lsp-mcp.configuration.outputFormat.description%"
        },
        "lsp-mcp.mcpLocale": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "en",
            "zh-cn"
          ],
          "description": "%lsp-mcp.configuration.mcpLocale.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --sourcemap",
    "lint": "eslint src --fix",
    "prepare": "git config core.hooksPath .githooks",
    "vscode:prepublish": "pnpm build",
    "vsix": "vsce package --no-dependencies --out lsp-mcp.vsix",
    "release:prepare": "pnpm test && pnpm typecheck && pnpm vsix",
    "release:vscode": "pnpm release:prepare && vsce publish --no-dependencies --packagePath lsp-mcp.vsix",
    "release:open-vsx": "pnpm release:prepare && ovsx publish --no-dependencies lsp-mcp.vsix",
    "release:all": "pnpm release:prepare && vsce publish --no-dependencies --packagePath lsp-mcp.vsix && ovsx publish --no-dependencies lsp-mcp.vsix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "express": "^5.1.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.2.1",
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.4",
    "@types/vscode": "1.101.0",
    "@vscode/vsce": "^3.2.2",
    "eslint": "^9.20.1",
    "lint-staged": "^17.0.8",
    "ovsx": "^1.0.2",
    "reactive-vscode": "^0.2.10",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "3.0.5"
  },
  "lint-staged": {
    "*.{ts,js}": "eslint --fix"
  }
}
